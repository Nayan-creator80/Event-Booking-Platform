# Database Connection
DATABASE_URL="postgresql://capstone:capstone@localhost:5432/capstone_db?schema=public"

# Server Configuration
PORT=4000
NODE_ENV=development

# JWT Authentication Config
JWT_SECRET="generate-a-secure-random-secret-for-access-tokens"
JWT_REFRESH_SECRET="generate-a-secure-random-secret-for-refresh-tokens"
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"

# CORS Configuration
CLIENT_ORIGIN="http://localhost:3000"
